#run frontend: npm run dev
#run backend: uvicorn backend.main:app --reload

# ─── Python / Backend ────────────────────────────────────────────────────────

# Virtual environment — contains gigabytes of installed packages.
# Every developer creates their own with: python -m venv venv
venv/
env/
.env/
.venv/

# Python bytecode cache — auto-generated, not source code
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging artifacts (not used in Phase 1, but good practice)
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest cache and coverage reports
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# MyPy type checker cache
.mypy_cache/

# Ruff / flake8 linter cache
.ruff_cache/

# Environment variable files — NEVER commit secrets, API keys, or passwords
.env
.env.local
.env.*.local
*.env

# Uploaded PDF files — user data should never be committed
backend/uploads/
backend/*.pdf
*.pdf


# ─── Node / Frontend ─────────────────────────────────────────────────────────

# node_modules is hundreds of MB — restored by running: npm install
frontend/node_modules/
node_modules/

# Vite build output — generated by: npm run build
frontend/dist/
frontend/.vite/

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Parcel cache (not used here, but common in JS projects)
.parcel-cache/


# ─── IDEs & Editors ──────────────────────────────────────────────────────────

# VS Code — workspace settings are machine-specific (except .vscode/extensions.json)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim swap files
*.swp
*.swo
*~

# macOS metadata files (created automatically by Finder)
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail cache
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux trash folder
.Trash-*


# ─── Jupyter Notebooks (Phase 2+ experiments) ────────────────────────────────

# Checkpoint files are auto-saved clutter
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# ─── Vector DB / AI artefacts (Phase 3+) ────────────────────────────────────

# ChromaDB / FAISS local databases — large binary files, rebuilt from source
chroma_db/
faiss_index/
*.index
*.pkl
*.bin

# Sentence-transformer / HuggingFace model caches
.cache/
models/


# ─── Misc ────────────────────────────────────────────────────────────────────

# Compressed archives
*.zip
*.tar.gz
*.rar

# Log files
*.log
logs/

# Temporary files
*.tmp
*.temp
tmp/
temp/

